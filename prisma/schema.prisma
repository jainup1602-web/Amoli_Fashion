generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model banner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?  @db.Text
  image       String   @db.LongText
  link        String?  @db.LongText
  buttonText  String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive], map: "Banner_isActive_idx")
  @@index([order], map: "Banner_order_idx")
}

model cart {
  id          String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "Cart_productId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Cart_userId_fkey")

  @@unique([userId, productId], map: "Cart_userId_productId_key")
  @@index([productId], map: "Cart_productId_idx")
  @@index([userId], map: "Cart_userId_idx")
}

model category {
  id          String        @id @default(uuid())
  name        String        @unique(map: "Category_name_key")
  slug        String        @unique(map: "Category_slug_key")
  description String?       @db.Text
  image       String?       @db.Text
  isActive    Boolean       @default(true)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  product     product[]
  subcategory subcategory[]

  @@index([slug], map: "Category_slug_idx")
}

model cmspage {
  id          String   @id @default(uuid())
  title           String
  slug            String   @unique(map: "CmsPage_slug_key")
  content         String   @db.LongText
  metaTitle       String?
  metaDescription String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug], map: "CmsPage_slug_idx")
}

model coupon {
  id          String   @id @default(uuid())
  code                 String   @unique(map: "Coupon_code_key")
  description          String?  @db.Text
  discountType         String
  discountValue        Float
  minOrderValue        Float?
  maxDiscount          Float?
  usageLimit           Int?
  usedCount            Int      @default(0)
  validFrom            DateTime
  validUntil           DateTime
  isActive             Boolean  @default(true)
  applicableProducts   String?  @db.LongText
  applicableCategories String?  @db.LongText
  createdAt            DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code], map: "Coupon_code_idx")
  @@index([isActive], map: "Coupon_isActive_idx")
}

model enquiry {
  id          String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email], map: "Enquiry_email_idx")
  @@index([status], map: "Enquiry_status_idx")
}

model modelgallery {
  id          String   @id @default(uuid())
  modelName   String
  image       String   @db.Text
  description String?  @db.Text
  category    String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive], map: "ModelGallery_isActive_idx")
  @@index([order], map: "ModelGallery_order_idx")
}

model newsletter {
  id          String   @id @default(uuid())
  email     String   @unique(map: "Newsletter_email_key")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([email], map: "Newsletter_email_idx")
}

model notification {
  id          String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String
  link      String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Notification_userId_fkey")

  @@index([createdAt], map: "Notification_createdAt_idx")
  @@index([isRead], map: "Notification_isRead_idx")
  @@index([userId], map: "Notification_userId_idx")
}

model order {
  id          String   @id @default(uuid())
  orderNumber       String      @unique(map: "Order_orderNumber_key")
  userId            String
  customerName      String
  customerEmail     String?
  customerPhone     String
  shippingAddress   String      @db.LongText
  billingAddress    String?     @db.LongText
  subtotal          Float
  discount          Float       @default(0)
  shippingCharges   Float       @default(0)
  tax               Float       @default(0)
  total             Float
  couponCode        String?
  paymentMethod     String
  paymentStatus     String      @default("pending")
  razorpayOrderId   String?
  razorpayPaymentId String?
  orderStatus       String      @default("pending")
  trackingNumber    String?
  shippingProvider  String?
  notes             String?     @db.Text
  cancelReason      String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt   DateTime @updatedAt
  user              user        @relation(fields: [userId], references: [id], map: "Order_userId_fkey")
  orderitem         orderitem[]

  @@index([orderNumber], map: "Order_orderNumber_idx")
  @@index([orderStatus], map: "Order_orderStatus_idx")
  @@index([paymentStatus], map: "Order_paymentStatus_idx")
  @@index([userId], map: "Order_userId_idx")
}

model orderitem {
  id          String   @id @default(uuid())
  orderId   String
  productId String
  name      String
  image     String  @db.Text
  price     Float
  quantity  Int
  subtotal  Float
  order     order   @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "OrderItem_orderId_fkey")
  product   product @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_idx")
  @@index([productId], map: "OrderItem_productId_idx")
}

model popup {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?  @db.Text
  image       String?  @db.LongText
  offerText   String?  @db.Text
  buttonText  String   @default("Shop Now")
  buttonLink  String   @default("/products")
  isActive    Boolean  @default(true)
  showDelay   Int      @default(2000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive], map: "Popup_isActive_idx")
}

model product {
  id                 String       @id @default(uuid())
  name               String
  slug               String       @unique(map: "Product_slug_key")
  description        String       @db.Text
  shortDescription   String?      @db.Text
  images             String       @db.LongText
  categoryId         String
  subcategoryId      String?
  originalPrice      Float
  specialPrice       Float?
  discountPercentage Float?
  stock              Int          @default(0)
  sku                String?      @unique(map: "Product_sku_key")
  weight             Float?
  dimensions         String?      @db.LongText
  material           String?
  purity             String?
  occasion           String?
  gender             String?
  tags               String?      @db.LongText
  isFeatured         Boolean      @default(false)
  isActive           Boolean      @default(true)
  views              Int          @default(0)
  salesCount         Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  cart               cart[]
  orderitem          orderitem[]
  category           category     @relation(fields: [categoryId], references: [id], map: "Product_categoryId_fkey")
  subcategory        subcategory? @relation(fields: [subcategoryId], references: [id], map: "Product_subcategoryId_fkey")
  review             review[]
  wishlist           wishlist[]

  @@index([categoryId], map: "Product_categoryId_idx")
  @@index([isFeatured], map: "Product_isFeatured_idx")
  @@index([slug], map: "Product_slug_idx")
  @@index([subcategoryId], map: "Product_subcategoryId_idx")
}

model review {
  id          String   @id @default(uuid())
  productId  String
  userId     String
  userName   String
  rating     Int
  comment    String   @db.Text
  images     String?  @db.LongText
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product    product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "Review_productId_fkey")
  user       user     @relation(fields: [userId], references: [id], map: "Review_userId_fkey")

  @@index([isApproved], map: "Review_isApproved_idx")
  @@index([productId], map: "Review_productId_idx")
  @@index([userId], map: "Review_userId_idx")
}

model settings {
  id          String   @id @default(uuid())
  key       String   @unique(map: "Settings_key_key")
  value     String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key], map: "Settings_key_idx")
}

model shippingzone {
  id          String   @id @default(uuid())
  name      String
  pincodes  String   @db.LongText
  charges   Float
  freeAbove Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive], map: "ShippingZone_isActive_idx")
}

model showcase {
  id          String   @id @default(uuid())
  title     String
  subtitle  String?
  image     String   @db.Text
  link      String?  @db.Text
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive], map: "Showcase_isActive_idx")
  @@index([order], map: "Showcase_order_idx")
}

model subcategory {
  id          String   @id @default(uuid())
  name        String
  slug        String    @unique(map: "Subcategory_slug_key")
  description String?   @db.Text
  image       String?   @db.Text
  categoryId  String
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  product     product[]
  category    category  @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "Subcategory_categoryId_fkey")

  @@index([categoryId], map: "Subcategory_categoryId_idx")
  @@index([slug], map: "Subcategory_slug_idx")
}

model user {
  id          String   @id @default(uuid())
  firebaseUid  String?        @unique(map: "User_firebaseUid_key")
  email        String?        @unique(map: "User_email_key")
  phoneNumber  String?        @unique(map: "User_phoneNumber_key")
  displayName  String?
  photoURL     String?        @db.Text
  role         String         @default("customer")
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt   DateTime @updatedAt
  cart         cart[]
  notification notification[]
  order        order[]
  review       review[]
  wishlist     wishlist[]

  @@index([email], map: "User_email_idx")
  @@index([firebaseUid], map: "User_firebaseUid_idx")
  @@index([phoneNumber], map: "User_phoneNumber_idx")
}

model videoreview {
  id          String   @id @default(uuid())
  customerName     String
  customerLocation String?
  rating           Int
  videoUrl         String   @db.LongText
  thumbnailUrl     String?  @db.LongText
  isActive         Boolean  @default(true)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive], map: "VideoReview_isActive_idx")
  @@index([order], map: "VideoReview_order_idx")
}

model wishlist {
  id          String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "Wishlist_productId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Wishlist_userId_fkey")

  @@unique([userId, productId], map: "Wishlist_userId_productId_key")
  @@index([productId], map: "Wishlist_productId_idx")
  @@index([userId], map: "Wishlist_userId_idx")
}
